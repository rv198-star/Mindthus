{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindthus.dev/schemas/beta2-arm-manifest-v0.1.json",
  "title": "Mindthus 2.0 Beta.2 sealed evaluation arm",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "arm_id",
    "surface",
    "definition_sha256",
    "schema_sha256",
    "package",
    "carrier",
    "host",
    "runtime_diagnostic",
    "model",
    "tools",
    "ambient_context",
    "identity_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "mindthus-beta2-arm-manifest-v0.1"
    },
    "arm_id": {
      "enum": [
        "stable",
        "direct-only",
        "thin-kernel"
      ]
    },
    "surface": {
      "enum": [
        "codex-plugin",
        "claude-plugin"
      ]
    },
    "definition_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "schema_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "coordinate",
        "namespace_prefix",
        "tree_sha256",
        "manifest"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "coordinate": {
          "type": "string",
          "minLength": 1
        },
        "namespace_prefix": {
          "type": "string",
          "minLength": 1
        },
        "tree_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifest": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "name",
            "version",
            "default_prompt_sha256"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "default_prompt_sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      }
    },
    "carrier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "hook_state",
        "config"
      ],
      "properties": {
        "policy": {
          "enum": [
            "stable-router",
            "disabled",
            "session-start-kernel"
          ]
        },
        "hook_state": {
          "enum": [
            "not-applicable",
            "disabled",
            "fired"
          ]
        },
        "config": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/fileReceipt"
            }
          ]
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "home",
        "execution_root",
        "runtime",
        "cli",
        "config_files",
        "plugin_list"
      ],
      "properties": {
        "home": {
          "type": "string",
          "minLength": 1
        },
        "execution_root": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version",
            "platform"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "platform": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "cli": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "enum": [
                "codex",
                "claude"
              ]
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "config_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fileReceipt"
          }
        },
        "plugin_list": {
          "allOf": [
            {
              "$ref": "#/$defs/fileReceipt"
            },
            {
              "type": "object",
              "required": [
                "source_command",
                "active_mindthus_coordinates"
              ],
              "properties": {
                "source_command": {
                  "type": "string",
                  "minLength": 1
                },
                "active_mindthus_coordinates": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          ]
        }
      }
    },
    "runtime_diagnostic": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "schema_version",
            "integrity",
            "carrier_status",
            "hook_state",
            "runtime_isolation_status",
            "passive_kernel_status",
            "direct_owner_status"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "schema_version": {
              "const": "mindthus-beta-runtime-diagnostic-v0.2"
            },
            "integrity": {
              "const": "ok"
            },
            "carrier_status": {
              "const": "verified"
            },
            "hook_state": {
              "enum": [
                "disabled",
                "fired"
              ]
            },
            "runtime_isolation_status": {
              "const": "isolated-observed"
            },
            "passive_kernel_status": {
              "enum": [
                "degraded",
                "reported-fired-carrier-verified"
              ]
            },
            "direct_owner_status": {
              "const": "packaged-verified"
            }
          }
        }
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reasoning"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tools": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ambient_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "opaque",
        "discovered_agents_files",
        "default_prompt_sha256"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "$ref": "#/$defs/fileReceipt"
              },
              {
                "type": "object",
                "required": [
                  "kind",
                  "id"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "minLength": 1
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        },
        "opaque": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "id",
              "sha256"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        },
        "discovered_agents_files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "default_prompt_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "identity_digest": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "fileReceipt": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
