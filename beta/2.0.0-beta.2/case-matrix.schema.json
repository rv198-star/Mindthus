{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindthus.dev/schemas/beta2-case-matrix-v0.1.json",
  "title": "Mindthus 2.0 Beta.2 provenance-aware case matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "coverage_requirements", "cases"],
  "properties": {
    "schema_version": { "const": "mindthus-beta2-case-matrix-v0.1" },
    "coverage_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owners",
        "primitives",
        "lifecycle_paths",
        "near_negatives",
        "anti_spiral_sequences",
        "provenance_classes",
        "entry_modes"
      ],
      "properties": {
        "owners": { "$ref": "#/$defs/uniqueStrings" },
        "primitives": { "$ref": "#/$defs/uniqueStrings" },
        "lifecycle_paths": { "$ref": "#/$defs/uniqueStrings" },
        "near_negatives": { "$ref": "#/$defs/uniqueStrings" },
        "anti_spiral_sequences": { "$ref": "#/$defs/uniqueStrings" },
        "provenance_classes": { "$ref": "#/$defs/uniqueStrings" },
        "entry_modes": { "$ref": "#/$defs/uniqueStrings" }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "uniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "sha256OrNull": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locator",
        "receipt_sha256",
        "implementation_visible",
        "run_eligibility"
      ],
      "properties": {
        "locator": { "type": "string", "minLength": 1 },
        "receipt_sha256": { "$ref": "#/$defs/sha256OrNull" },
        "implementation_visible": { "type": "boolean" },
        "run_eligibility": {
          "enum": ["eligible", "requires-custodian-attestation", "requires-user-authorization"]
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "title",
        "case_type",
        "provenance",
        "source",
        "entry_mode",
        "lifecycle_path",
        "expected_execution_owner",
        "accepted_execution_owners",
        "expected_primitive_obligations",
        "required_visible_action",
        "required_skill_loads",
        "allowed_skill_loads",
        "stay_asleep_expected",
        "expected_lifecycle_events",
        "evidence_first_expected",
        "contamination_risk",
        "coverage_tags"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "case_type": { "enum": ["positive", "negative_control"] },
        "provenance": {
          "enum": ["public-regression", "development", "sealed-shadow", "real-task-replay"]
        },
        "source": { "$ref": "#/$defs/source" },
        "entry_mode": {
          "enum": ["owner-direct", "passive-kernel", "arbitrator", "stay-asleep", "evidence-first"]
        },
        "lifecycle_path": { "enum": ["startup", "resume", "clear", "compact"] },
        "expected_execution_owner": { "type": "string", "minLength": 1 },
        "accepted_execution_owners": { "$ref": "#/$defs/uniqueStrings" },
        "expected_primitive_obligations": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_visible_action": { "type": ["string", "null"] },
        "required_skill_loads": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowed_skill_loads": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "stay_asleep_expected": { "type": "boolean" },
        "expected_lifecycle_events": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["session-start", "before-route", "before-answer", "before-continue", "before-freeze"]
          }
        },
        "evidence_first_expected": { "type": "boolean" },
        "contamination_risk": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "reason"],
          "properties": {
            "level": { "enum": ["low", "medium", "high"] },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "coverage_tags": { "$ref": "#/$defs/uniqueStrings" }
      }
    }
  }
}
