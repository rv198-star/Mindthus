{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindthus.dev/schemas/beta2-dry-run-plan-v0.3.json",
  "title": "Mindthus 2.0 Beta.2 visible-case Codex deterministic dry-run plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "executor",
    "model_execution_allowed",
    "protocol_path",
    "protocol_sha256",
    "protocol_lock_path",
    "protocol_validator_path",
    "protocol_validator_sha256",
    "case_matrix_path",
    "case_matrix_sha256",
    "arm_manifests",
    "host_observations",
    "judge_environment_path",
    "judge_environment_sha256",
    "dry_run_case_ids",
    "required_lifecycle_paths",
    "supported_surfaces",
    "negative_fixture_catalog",
    "plan_digest"
  ],
  "properties": {
    "schema_version": { "const": "mindthus-beta2-dry-run-plan-v0.3" },
    "executor": { "const": "deterministic-mock-only" },
    "model_execution_allowed": { "const": false },
    "protocol_path": { "type": "string", "minLength": 1 },
    "protocol_sha256": { "$ref": "#/$defs/sha256" },
    "protocol_lock_path": { "type": "string", "minLength": 1 },
    "protocol_validator_path": { "type": "string", "minLength": 1 },
    "protocol_validator_sha256": { "$ref": "#/$defs/sha256" },
    "case_matrix_path": { "type": "string", "minLength": 1 },
    "case_matrix_sha256": { "$ref": "#/$defs/sha256" },
    "arm_manifests": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "host_observations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "manifest_path",
          "identity_digest",
          "active_mindthus_coordinates",
          "hook_state",
          "package_tree_sha256",
          "ambient_context_sha256",
          "resource_probe_path"
        ],
        "properties": {
          "manifest_path": { "type": "string", "minLength": 1 },
          "identity_digest": { "$ref": "#/$defs/sha256" },
          "active_mindthus_coordinates": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "hook_state": { "enum": ["not-applicable", "disabled", "fired"] },
          "package_tree_sha256": { "$ref": "#/$defs/sha256" },
          "ambient_context_sha256": { "$ref": "#/$defs/sha256" },
          "resource_probe_path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "judge_environment_path": { "type": "string", "minLength": 1 },
    "judge_environment_sha256": { "$ref": "#/$defs/sha256" },
    "dry_run_case_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_lifecycle_paths": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "enum": ["startup", "resume", "clear", "compact"] }
    },
    "supported_surfaces": { "const": ["codex-plugin"] },
    "negative_fixture_catalog": { "type": "string", "minLength": 1 },
    "plan_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
