{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindthus.dev/schemas/beta2-dry-run-report-v0.1.json",
  "title": "Mindthus 2.0 Beta.2 deterministic dry-run report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "executor",
    "plan_digest",
    "protocol_sha256",
    "protocol_lock_digest",
    "expected_cell_count",
    "completed_cell_count",
    "new_cell_count",
    "skipped_completed_cell_count",
    "surfaces",
    "arms",
    "lifecycle_paths",
    "model_calls",
    "judge_model_calls",
    "semantic_model_output_count",
    "semantic_claims_available",
    "orchestration_claims_available",
    "claims_unavailable_until_real_model_execution",
    "release_readiness",
    "fault",
    "veto_id",
    "reason",
    "report_digest"
  ],
  "properties": {
    "schema_version": { "const": "mindthus-beta2-dry-run-report-v0.1" },
    "status": { "enum": ["passed", "interrupted", "vetoed"] },
    "executor": { "const": "deterministic-mock-only" },
    "plan_digest": { "$ref": "#/$defs/nullableSha256" },
    "protocol_sha256": { "$ref": "#/$defs/nullableSha256" },
    "protocol_lock_digest": { "$ref": "#/$defs/nullableSha256" },
    "expected_cell_count": { "type": "integer", "minimum": 0 },
    "completed_cell_count": { "type": "integer", "minimum": 0 },
    "new_cell_count": { "type": "integer", "minimum": 0 },
    "skipped_completed_cell_count": { "type": "integer", "minimum": 0 },
    "surfaces": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "arms": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "lifecycle_paths": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "model_calls": { "const": 0 },
    "judge_model_calls": { "const": 0 },
    "semantic_model_output_count": { "const": 0 },
    "semantic_claims_available": { "type": "array", "maxItems": 0 },
    "orchestration_claims_available": { "type": "array", "items": { "type": "string" } },
    "claims_unavailable_until_real_model_execution": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "release_readiness": { "const": "not-assessed" },
    "fault": { "type": ["string", "null"] },
    "veto_id": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "report_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nullableSha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
