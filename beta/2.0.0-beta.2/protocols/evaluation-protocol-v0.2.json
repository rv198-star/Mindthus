  "primary_endpoints": [
    {
      "id": "quality_noninferiority_vs_stable",
      "domain": "quality",
      "status": "resolved",
      "metric": "mean normalized blinded final-answer score",
      "comparison": "thin-kernel minus stable",
      "direction": "higher-is-better",
      "margin": {
        "kind": "noninferiority-delta",
        "value": -0.05,
        "unit": "proportion"
      },
      "decision_rule": "lower 95% paired interval must be >= -0.05 on the Codex surface",
      "required_evidence": [
        {
          "endpoint": "judge.normalized_final_answer_score",
          "allowed_provenance": [
            "judge-inferred"
          ],
          "minimum_per_cell": 2
        }
      ],
      "missing_policy": "veto"
    },
