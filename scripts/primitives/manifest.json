    "tplan": {
      "before-freeze": {
        "intervention_points": [
          "mission_update_or_handoff_freeze",
          "decision_packet_freeze"
        ],
        "active_primitives": [
          "evidence_claim_ceiling",
          "no_abstract_jargon_wall"
        ],
        "required_agent_checks": [
          "gate_probe_current_position_and_next_action",
