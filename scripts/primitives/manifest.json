  "primitives": {
    "evidence_claim_ceiling": {
      "name": "Evidence / Claim Ceiling / 证据上限",
      "short_rule": "结论强度不能超过证据；缺关键事实时降级或阻断。",
      "trigger": [
        "before-route",
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "downgrade-claim",
        "gather-evidence",
        "block",
        "stop"
      ],
      "not_a": [
        "fact-generator",
        "evidence-substitute"
      ],
      "owner": "primitives/evidence-claim-ceiling"
    },
    "perspective_pressure": {
      "name": "Perspective Pressure / 视角施压",
      "short_rule": "单一视角过度自洽时，用角色、激励或反方视角挑战判断。",
      "trigger": [
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "challenge",
        "rebuild",
        "downgrade-claim",
        "block"
      ],
      "not_a": [
        "standalone-method",
        "debate-theater",
        "semantic-judge"
      ],
      "owner": "primitives/perspective-pressure"
    },
    "no_abstract_jargon_wall": {
      "name": "No Abstract Jargon Wall / 先说人话",
      "short_rule": "先确认立场和服务对象，用具体后果讲清楚，再使用方法名。",
      "trigger": [
        "before-route",
        "before-freeze"
      ],
      "action_effect": [
        "rewrite",
        "audience-position",
        "remove-jargon",
        "handoff"
      ],
      "not_a": [
        "style-polish",
        "semantic-judge"
      ],
      "owner": "primitives/no-abstract-jargon-wall"
    },
    "approximate_quantified_mapping": {
      "name": "Approximate Quantified Mapping / 非精准量化显影",
      "short_rule": "数字是假设，关系才是重点；只显影变量关系，不计算结论。",
      "trigger": [
        "before-freeze"
      ],
      "action_effect": [
        "expose-variables",
        "clarify-dominant-term",
        "downgrade-numeric-claim",
        "return-to-evidence"
      ],
      "not_a": [
        "calculator",
        "measurement",
        "decision-engine",
        "semantic-judge"
      ],
      "owner": "primitives/approximate-quantified-mapping"
    },
    "anti_spiral": {
      "name": "Anti-Spiral / 反螺旋",
      "short_rule": "同一局部对象第三次、负反馈或加层冲动出现时，先停下回看上游。",
      "trigger": [
        "before-continue"
      ],
      "action_effect": [
        "stop",
        "return-upstream",
        "subtract",
        "reroute",
        "ask-user-authority"
      ],
      "not_a": [
        "standalone-method",
        "automatic-stop-rule"
      ],
      "owner": "primitives/anti-spiral"
    }
  }
}
