{
  "schema_version": "mindthus-primitive-activation-v0.1",
  "script_boundary": "shape_only_reminder_not_semantic_judgment",
  "events": {
    "before-route": {
      "description": "Before selecting a Mindthus method.",
      "active_primitives": [
        "minimal_sufficient_lens",
        "frame_fitness_check",
        "whole_elephant_protocol",
        "evidence_claim_ceiling"
      ],
      "required_agent_checks": [
        "is_this_clear_low_risk_direct_execution",
        "is_input_a_question_or_packed_conclusion",
        "is_a_local_frame_claiming_global_authority",
        "if_partial_truth_triggers_validate_whole_elephant_audit",
        "are_facts_or_runtime_proof_missing",
        "what_hard_judgment_point_exists",
        "which_method_owns_the_next_judgment"
      ]
    },
    "before-answer": {
      "description": "Before producing a formal answer after frame-risk or partial-truth capture.",
      "active_primitives": [
        "whole_elephant_protocol",
        "core_thesis_extraction",
        "first_sentence_stress_test",
        "essence_wording_guard"
      ],
      "required_agent_checks": [
        "build_compact_visible_audit",
        "validate_whole_elephant_audit_when_triggered",
        "start_formal_answer_with_core_thesis",
        "ensure_no_second_question_gap",
        "reject_false_essence_claim_when_disposition_rejects_definition"
      ]
    },
    "before-freeze": {
      "description": "Before deliver, freeze, handoff, block, or stop.",
      "active_primitives": [
        "gate_probes",
        "failure_smells",
        "evidence_claim_ceiling"
      ],
      "required_agent_checks": [
        "current_artifact_or_action_role",
        "current_state_against_target",
        "evidence_boundary_and_claim_ceiling",
        "failure_smell_scan",
        "next_action_or_downstream_user"
      ]
    },
    "before-continue": {
      "description": "Before continuing the same path or another value-gain/runtime round.",
      "active_primitives": [
        "gate_probes",
        "anti_spiral",
        "failure_smells"
      ],
      "conditional_primitives": [
        {
          "primitive": "continuation_authorization",
          "method": "tplan"
        }
      ],
      "required_agent_checks": [
        "why_same_path_is_still_authorized",
        "next_round_positive_value_or_evidence_delta",
        "local_repair_spiral_risk",
        "failure_smell_scan",
        "stop_or_handoff_condition"
      ]
    }
  },
  "primitives": {
    "minimal_sufficient_lens": {
      "name": "Minimal Sufficient Lens / 最小充分镜头",
      "short_rule": "能直接判断就不要开方法；一个 skill 足够就不要串联。",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "direct-execute",
        "route",
        "acquire-information",
        "stop"
      ],
      "not_a": [
        "method-router-replacement",
        "semantic-judge"
      ],
      "owner": "using-mindthus"
    },
    "evidence_claim_ceiling": {
      "name": "Evidence / Claim Ceiling / 证据上限",
      "short_rule": "结论强度不能超过证据；缺关键事实时降级或阻断。",
      "trigger": [
        "before-route",
        "before-freeze"
      ],
      "action_effect": [
        "downgrade-claim",
        "gather-evidence",
        "block",
        "stop"
      ],
      "not_a": [
        "fact-generator",
        "evidence-substitute"
      ],
      "owner": "WAE"
    },
    "frame_fitness_check": {
      "name": "Frame Fitness Check / 定框适配检查",
      "short_rule": "局部框架可能接管全局判断时，先判断保留、限定、重构或因证据不足阻断。",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "audit-input-framing",
        "preserve-frame",
        "qualify-frame",
        "reframe",
        "block-pending-evidence",
        "route"
      ],
      "not_a": [
        "standalone-method",
        "contrarianism-engine",
        "semantic-judge",
        "decorative-template",
        "user-preference-eraser"
      ],
      "output_shape": [
        "true_question",
        "packed_premises",
        "layer_risks",
        "frame_status",
        "reframed_question",
        "routing_decision"
      ],
      "frame_status_values": [
        "clean",
        "biased",
        "overloaded",
        "malformed"
      ],
      "routing_effect": {
        "clean": "normal-route",
        "biased": "name-bias-then-route",
        "overloaded": "split-propositions-then-route",
        "malformed": "correct-question-before-analysis"
      },
      "owner": "using-mindthus"
    },
    "whole_elephant_protocol": {
      "name": "Whole Elephant Protocol / 全象流程",
      "short_rule": "局部真相可能冒充整体时，先产出可校验全象审计包，再进入正式判断。",
      "trigger": [
        "before-route",
        "before-answer"
      ],
      "action_effect": [
        "validate-whole-elephant-audit",
        "reconstruct-whole-object",
        "map-local-success-points",
        "choose-strategy",
        "decide-definition-disposition",
        "name-result-controller",
        "name-decision-consequence",
        "name-optimization-misdirection",
        "plan-formal-answer"
      ],
      "not_a": [
        "standalone-method",
        "semantic-judge",
        "definition-decider",
        "domain-answer-generator"
      ],
      "output_shape": [
        "object_hierarchy",
        "user_named_object_relation",
        "canonical_object",
        "formal_thesis_subject",
        "umbrella_context",
        "subject_alignment_reason",
        "whole_object_reconstruction",
        "variant_map",
        "primary_value_distribution",
        "control_owner_shift",
        "formal_answer_plan",
        "whole_object",
        "local_success_points",
        "strategy_choice",
        "corrected_thesis",
        "definition_owner",
        "result_controller",
        "decision_consequence"
      ],
      "owner": "shared-primitives"
    },
    "core_thesis_extraction": {
      "name": "Core Thesis Extraction / 主判断收束",
      "short_rule": "正式回答首句必须承载主判断，不把最强句埋到后面。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "start-with-core-thesis",
        "name-corrected-owner-or-carrier",
        "name-practical-consequence"
      ],
      "not_a": [
        "style-polish",
        "summary-label",
        "semantic-judge"
      ],
      "output_shape": [
        "opening_core_thesis",
        "corrected_owner_or_carrier",
        "practical_consequence"
      ],
      "owner": "shared-primitives"
    },
    "first_sentence_stress_test": {
      "name": "First Sentence Stress Test / 首句主判断压力测试",
      "short_rule": "如果读者还要追问第二句才抓到重点，首句失败。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "prevent-buried-core",
        "name-global-thesis-first",
        "deny-local-definition-authority",
        "name-target-result",
        "name-optimization-consequence",
        "translate-definition-authority-to-final-say",
        "name-controller-inversion-when-variants-differ",
        "apply-result-controller-viewpoint"
      ],
      "not_a": [
        "rhetorical-sharpness-only",
        "style-polish",
        "semantic-judge"
      ],
      "output_shape": [
        "target_result",
        "corrected_owner_or_carrier",
        "final_say_language",
        "controller_inversion",
        "result_controller_viewpoint",
        "local_interface_role",
        "optimization_consequence"
      ],
      "owner": "shared-primitives"
    },
    "essence_wording_guard": {
      "name": "Essence Wording Guard / 本质措辞护栏",
      "short_rule": "不要把局部载体或接口重新说成本质。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "reject-false-essence-wording",
        "preserve-local-truth-boundary",
        "name-definition-disposition"
      ],
      "not_a": [
        "contrarianism-engine",
        "semantic-judge"
      ],
      "owner": "shared-primitives"
    },
    "gate_probes": {
      "name": "Gate Probes / 冻结前定位自省",
      "short_rule": "交付、冻结、继续、转交或停止前，确认当前位置和目标。",
      "trigger": [
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "freeze",
        "return-remediate",
        "block",
        "stop",
        "ask-user-authority"
      ],
      "not_a": [
        "standalone-method",
        "semantic-judge",
        "evidence-substitute",
        "gate-replacement"
      ],
      "owner": "shared-primitives"
    },
    "failure_smells": {
      "name": "Failure Smells / 误用信号",
      "short_rule": "看见像完成但没推进的信号时先自审；普通信号返修，硬边界阻断。",
      "trigger": [
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "self-audit",
        "return-remediate",
        "downgrade-claim",
        "reroute",
        "block",
        "stop"
      ],
      "not_a": [
        "mechanical-block-list",
        "semantic-judge"
      ],
      "owner": "shared-primitives"
    },
    "anti_spiral": {
      "name": "Anti-Spiral / 反螺旋",
      "short_rule": "同一局部对象第三次、负反馈或加层冲动出现时，先停下回看上游。",
      "trigger": [
        "before-continue"
      ],
      "action_effect": [
        "stop",
        "return-upstream",
        "subtract",
        "reroute",
        "ask-user-authority"
      ],
      "not_a": [
        "standalone-method",
        "automatic-stop-rule"
      ],
      "owner": "anti-spiral-self-audit"
    },
    "continuation_authorization": {
      "name": "Continuation Authorization / 继续授权",
      "short_rule": "同路径继续前说明继续凭什么被授权，以及下一步会带来什么新证据。",
      "trigger": [
        "before-continue"
      ],
      "action_effect": [
        "authorize-continue",
        "mission-review",
        "stop",
        "ask-user-authority"
      ],
      "not_a": [
        "generic-primitive",
        "evidence-substitute",
        "automatic-continue-rule"
      ],
      "owner": "tplan"
    }
  }
}
