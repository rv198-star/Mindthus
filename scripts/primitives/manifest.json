{
  "schema_version": "mindthus-primitive-activation-v0.1",
  "script_boundary": "shape_only_reminder_not_semantic_judgment",
  "ownership_calibration_scenarios": {
    "skills_prompt_essence": {
      "description": "A locally true prompt/context carrier tries to define SKILLS essence.",
      "expected_judgment_owner": "whole_elephant_protocol",
      "support_aspects": [
        "decision_context_calibration"
      ],
      "cues": [
        "local_truth_claims_whole_object_essence",
        "definition_authority_question",
        "implementation_carrier_overclaims_essence"
      ]
    },
    "display_scaling_op_usability": {
      "description": "A 27-inch 4K/5K/BetterDisplay debate turns on whose situated decision is being served.",
      "expected_judgment_owner": "decision_context_calibration",
      "support_aspects": [
        "whole_elephant_protocol"
      ],
      "cues": [
        "answer_flips_by_actor_timing_target_or_tradeoff",
        "situated_decision_judgment",
        "abstract_fairness_would_drift_from_user_goal"
      ]
    }
  },
  "events": {
    "before-route": {
      "description": "Before selecting a Mindthus method.",
      "active_primitives": [
        "minimal_sufficient_lens",
        "entry_triage",
        "frame_fitness_check",
        "mpg_scalar_commitment_unpack",
        "decision_context_calibration",
        "whole_elephant_protocol",
        "evidence_claim_ceiling"
      ],
      "required_agent_checks": [
        "is_this_clear_low_risk_direct_execution",
        "is_input_a_question_or_packed_conclusion",
        "which_entry_triage_family_if_any",
        "does_scalar_commitment_hide_mainline_carrier_path_exposure_commitment",
        "is_a_local_frame_claiming_global_authority",
        "does_answer_flip_by_actor_timing_target_or_tradeoff",
        "if_partial_truth_triggers_validate_whole_elephant_audit",
        "are_facts_or_runtime_proof_missing",
        "what_hard_judgment_point_exists",
        "which_aspect_owns_formal_answer_when_owner_candidates_conflict",
        "which_method_owns_the_next_judgment"
      ]
    },
    "before-answer": {
      "description": "Before producing a formal answer after frame-risk or partial-truth capture.",
      "active_primitives": [
        "decision_context_calibration",
        "whole_elephant_protocol",
        "core_thesis_extraction",
        "first_sentence_stress_test",
        "required_visible_action_probe",
        "essence_wording_guard"
      ],
      "required_agent_checks": [
        "build_internal_compact_audit",
        "validate_whole_elephant_audit_when_triggered",
        "choose_single_judgment_owner_when_owner_candidates_conflict",
        "do_not_average_aspect_outputs",
        "start_formal_answer_with_core_thesis",
        "ensure_no_second_question_gap",
        "ensure_required_visible_action_appears_in_prose",
        "reject_false_essence_claim_when_disposition_rejects_definition"
      ]
    },
    "before-freeze": {
      "description": "Before deliver, freeze, handoff, block, or stop.",
      "active_primitives": [
        "gate_probes",
        "failure_smells",
        "evidence_claim_ceiling"
      ],
      "required_agent_checks": [
        "current_artifact_or_action_role",
        "current_state_against_target",
        "evidence_boundary_and_claim_ceiling",
        "failure_smell_scan",
        "next_action_or_downstream_user"
      ]
    },
    "before-continue": {
      "description": "Before continuing the same path or another value-gain/runtime round.",
      "active_primitives": [
        "gate_probes",
        "anti_spiral",
        "failure_smells"
      ],
      "conditional_primitives": [
        {
          "primitive": "continuation_authorization",
          "method": "tplan"
        }
      ],
      "required_agent_checks": [
        "why_same_path_is_still_authorized",
        "next_round_positive_value_or_evidence_delta",
        "local_repair_spiral_risk",
        "failure_smell_scan",
        "stop_or_handoff_condition"
      ]
    }
  },
  "primitives": {
    "minimal_sufficient_lens": {
      "name": "Minimal Sufficient Lens / 最小充分镜头",
      "short_rule": "能直接判断就不要开方法；一个 skill 足够就不要串联。",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "direct-execute",
        "route",
        "acquire-information",
        "stop"
      ],
      "not_a": [
        "method-router-replacement",
        "semantic-judge"
      ],
      "owner": "using-mindthus"
    },
    "evidence_claim_ceiling": {
      "name": "Evidence / Claim Ceiling / 证据上限",
      "short_rule": "结论强度不能超过证据；缺关键事实时降级或阻断。",
      "trigger": [
        "before-route",
        "before-freeze"
      ],
      "action_effect": [
        "downgrade-claim",
        "gather-evidence",
        "block",
        "stop"
      ],
      "not_a": [
        "fact-generator",
        "evidence-substitute"
      ],
      "owner": "WAE"
    },
    "entry_triage": {
      "name": "Entry Triage / 入口分诊",
      "short_rule": "Before route, detect semantic disease families; wake methods only when a hard judgment point exists.",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "direct-execute",
        "route",
        "audit-input-framing",
        "activate-whole-elephant",
        "activate-decision-context",
        "activate-anti-spiral",
        "apply-evidence-ceiling",
        "root-cause-evidence-gate",
        "release-readiness-gate",
        "ask-target-function-before-migration",
        "whole-object-before-copy-or-essence-claim",
        "edsp-extreme-endpoints-before-branch",
        "anti-spiral-brake-before-addition",
        "no-computed-verdict-from-hypothetical-numbers",
        "method-reference-review-stays-direct"
      ],
      "not_a": [
        "keyword-router",
        "mandatory-workflow",
        "semantic-judge"
      ],
      "output_shape": [
        "disease_family",
        "hard_judgment_point",
        "route_candidate",
        "negative_control_risk"
      ],
      "owns_when": [
        "definition authority contest",
        "single-factor attribution",
        "local repair spiral",
        "forced binary prediction",
        "no-data numeric comparison",
        "trend-driven migration",
        "authority or tenure used as proof",
        "green tests used as release authorization",
        "business result reduced to one ingredient or metric",
        "essence claim over a local carrier",
        "method name used only as evidence-review scope"
      ],
      "degrade_to": [
        "direct_execution",
        "information_acquisition"
      ],
      "owner": "using-mindthus"
    },
    "frame_fitness_check": {
      "name": "Frame Fitness Check / 定框适配检查",
      "short_rule": "局部框架可能接管全局判断时，先判断保留、限定、重构或因证据不足阻断。",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "audit-input-framing",
        "preserve-frame",
        "qualify-frame",
        "reframe",
        "block-pending-evidence",
        "route"
      ],
      "not_a": [
        "standalone-method",
        "contrarianism-engine",
        "semantic-judge",
        "decorative-template",
        "user-preference-eraser"
      ],
      "output_shape": [
        "true_question",
        "packed_premises",
        "layer_risks",
        "frame_status",
        "reframed_question",
        "routing_decision"
      ],
      "frame_status_values": [
        "clean",
        "biased",
        "overloaded",
        "malformed"
      ],
      "routing_effect": {
        "clean": "normal-route",
        "biased": "name-bias-then-route",
        "overloaded": "split-propositions-then-route",
        "malformed": "correct-question-before-analysis"
      },
      "owner": "using-mindthus"
    },
    "mpg_scalar_commitment_unpack": {
      "name": "MPG Scalar Commitment Unpack / MPG 标量承诺显影",
      "short_rule": "路径波动下的单点承诺先显影 mainline/carrier/path/exposure/commitment；只改 MPG 路由输入，不下判断。",
      "trigger": [
        "before-route"
      ],
      "action_effect": [
        "surface-latent-vector",
        "route-mpg-ready",
        "ask-one-clarification",
        "defer-to-mainline-or-evidence",
        "not-applicable"
      ],
      "not_a": [
        "judgment-owner",
        "general-unpack-skill",
        "multi-round-interrogation",
        "mpg-decision-engine"
      ],
      "output_shape": [
        "mainline",
        "carrier",
        "path_volatility",
        "exposure",
        "commitment",
        "route_state",
        "one_clarification"
      ],
      "aspect_role": "support",
      "ownership_scope": [
        "method_routing_input_shape"
      ],
      "degrade_to": [
        "support_probe"
      ],
      "owner": "shared-primitives"
    },
    "decision_context_calibration": {
      "name": "Decision Context Calibration / 决策语境校准",
      "short_rule": "处境化判断先锁定决策者、时点、目标函数和可接受损耗；全局不是更抽象，而是对当前决策更有定义权。",
      "trigger": [
        "before-route",
        "before-answer"
      ],
      "action_effect": [
        "lock-decision-actor",
        "lock-decision-timing",
        "lock-target-function",
        "name-acceptable-tradeoff",
        "name-global-for-current-decision",
        "prevent-abstract-fairness-drift"
      ],
      "not_a": [
        "standalone-method",
        "semantic-judge",
        "preference-eraser",
        "abstract-neutrality-engine",
        "whole-elephant-replacement"
      ],
      "output_shape": [
        "decision_actor",
        "decision_timing",
        "target_function",
        "acceptable_tradeoff",
        "global_for_this_decision",
        "answer_posture"
      ],
      "aspect_role": "judgment_owner",
      "ownership_scope": [
        "formal_answer_thesis",
        "decision_target"
      ],
      "exclusive_with": [
        "whole_elephant_protocol"
      ],
      "owns_when": [
        "judgment depends on actor, timing, target function, or acceptable tradeoff",
        "who is right, worth it, should do, or acceptable changes by decision context",
        "abstract fairness would drift away from the active user's decision"
      ],
      "defer_when": [
        "core issue is essence, definition authority, or local mechanism capture",
        "answer would not flip after changing actor, timing, target function, or acceptable tradeoff"
      ],
      "degrade_to": [
        "support_probe"
      ],
      "owner": "shared-primitives"
    },
    "whole_elephant_protocol": {
      "name": "Whole Elephant Protocol / 全象流程",
      "short_rule": "局部真相可能冒充整体时，先锁定完整对象、结果主控和局部胜出后的优化偏移，再进入正式判断。",
      "trigger": [
        "before-route",
        "before-answer"
      ],
      "action_effect": [
        "validate-whole-elephant-audit",
        "build-compact-semantic-triad",
        "compare-local-frame-and-whole-object-consequences",
        "name-result-controller",
        "name-decision-consequence",
        "name-optimization-misdirection"
      ],
      "not_a": [
        "standalone-method",
        "semantic-judge",
        "definition-decider",
        "domain-answer-generator"
      ],
      "required_output_shape": [
        "canonical_object",
        "result_controller",
        "misdirection_if_local_wins",
        "local_frame_wins",
        "whole_object_wins",
        "better_direction_for_target"
      ],
      "expanded_debug_shape": [
        "object_hierarchy",
        "user_named_object_relation",
        "formal_thesis_subject",
        "umbrella_context",
        "subject_alignment_reason",
        "whole_object_reconstruction",
        "variant_map",
        "primary_value_distribution",
        "control_owner_shift",
        "formal_answer_plan",
        "whole_object",
        "local_success_points",
        "strategy_choice",
        "corrected_thesis",
        "definition_owner",
        "decision_consequence"
      ],
      "aspect_role": "judgment_owner",
      "ownership_scope": [
        "formal_answer_thesis",
        "definition_authority"
      ],
      "exclusive_with": [
        "decision_context_calibration"
      ],
      "owns_when": [
        "local truth claims whole-object essence",
        "carrier, implementation detail, single metric, or local mechanism tries to define the whole object",
        "the active question is definition authority rather than situated action choice"
      ],
      "defer_when": [
        "answer would flip by actor, timing, target function, or acceptable tradeoff",
        "the active question is who is right, worth it, should do, or acceptable for a situated decision"
      ],
      "degrade_to": [
        "support_probe"
      ],
      "owner": "shared-primitives"
    },
    "core_thesis_extraction": {
      "name": "Core Thesis Extraction / 主判断收束",
      "short_rule": "正式回答首句必须承载主判断，不把最强句埋到后面。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "start-with-core-thesis",
        "name-corrected-owner-or-carrier",
        "name-practical-consequence"
      ],
      "not_a": [
        "style-polish",
        "summary-label",
        "semantic-judge"
      ],
      "output_shape": [
        "opening_core_thesis",
        "corrected_owner_or_carrier",
        "practical_consequence"
      ],
      "owner": "shared-primitives"
    },
    "first_sentence_stress_test": {
      "name": "First Sentence Stress Test / 首句主判断压力测试",
      "short_rule": "如果读者还要追问第二句才抓到重点，首句失败。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "prevent-buried-core",
        "name-global-thesis-first",
        "deny-local-definition-authority",
        "name-target-result",
        "name-optimization-consequence",
        "translate-definition-authority-to-final-say",
        "name-controller-inversion-when-variants-differ",
        "apply-result-controller-viewpoint"
      ],
      "not_a": [
        "rhetorical-sharpness-only",
        "style-polish",
        "semantic-judge"
      ],
      "output_shape": [
        "target_result",
        "corrected_owner_or_carrier",
        "final_say_language",
        "controller_inversion",
        "result_controller_viewpoint",
        "local_interface_role",
        "optimization_consequence"
      ],
      "owner": "shared-primitives"
    },
    "required_visible_action_probe": {
      "name": "Required Visible Action Probe / 必需可见动作探针",
      "short_rule": "加载 owner 后，正式回答必须把该 case 的关键动作写进自然语言，而不是只完成内部审计。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "definition_authority_first_sentence",
        "visible_optimization_consequence",
        "edsp_extreme_endpoints_visible",
        "sela_order_of_magnitude_contrast_visible",
        "anti_spiral_brake_before_addition"
      ],
      "not_a": [
        "judgment-owner",
        "semantic-judge",
        "visible-audit-field-list"
      ],
      "aspect_role": "constraint",
      "ownership_scope": [
        "output_shape",
        "visible_action"
      ],
      "output_shape": [
        "visible_action_in_prose",
        "no_audit_field_list"
      ],
      "degrade_to": [
        "wording_constraint"
      ],
      "owner": "shared-primitives"
    },
    "essence_wording_guard": {
      "name": "Essence Wording Guard / 本质措辞护栏",
      "short_rule": "不要把局部载体或接口重新说成本质。",
      "trigger": [
        "before-answer"
      ],
      "action_effect": [
        "reject-false-essence-wording",
        "preserve-local-truth-boundary",
        "name-definition-disposition"
      ],
      "not_a": [
        "contrarianism-engine",
        "semantic-judge"
      ],
      "owner": "shared-primitives"
    },
    "gate_probes": {
      "name": "Gate Probes / 冻结前定位自省",
      "short_rule": "交付、冻结、继续、转交或停止前，确认当前位置和目标。",
      "trigger": [
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "freeze",
        "return-remediate",
        "block",
        "stop",
        "ask-user-authority"
      ],
      "not_a": [
        "standalone-method",
        "semantic-judge",
        "evidence-substitute",
        "gate-replacement"
      ],
      "owner": "shared-primitives"
    },
    "failure_smells": {
      "name": "Failure Smells / 误用信号",
      "short_rule": "看见像完成但没推进的信号时先自审；普通信号返修，硬边界阻断。",
      "trigger": [
        "before-freeze",
        "before-continue"
      ],
      "action_effect": [
        "self-audit",
        "return-remediate",
        "downgrade-claim",
        "reroute",
        "block",
        "stop"
      ],
      "not_a": [
        "mechanical-block-list",
        "semantic-judge"
      ],
      "owner": "shared-primitives"
    },
    "anti_spiral": {
      "name": "Anti-Spiral / 反螺旋",
      "short_rule": "同一局部对象第三次、负反馈或加层冲动出现时，先停下回看上游。",
      "trigger": [
        "before-continue"
      ],
      "action_effect": [
        "stop",
        "return-upstream",
        "subtract",
        "reroute",
        "ask-user-authority"
      ],
      "not_a": [
        "standalone-method",
        "automatic-stop-rule"
      ],
      "owner": "anti-spiral-self-audit"
    },
    "continuation_authorization": {
      "name": "Continuation Authorization / 继续授权",
      "short_rule": "同路径继续前说明继续凭什么被授权，以及下一步会带来什么新证据。",
      "trigger": [
        "before-continue"
      ],
      "action_effect": [
        "authorize-continue",
        "mission-review",
        "stop",
        "ask-user-authority"
      ],
      "not_a": [
        "generic-primitive",
        "evidence-substitute",
        "automatic-continue-rule"
      ],
      "owner": "tplan"
    }
  }
}
